---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<Layout
  title="記事一覧"
  description="うまミライの全記事一覧です。地方競馬の基礎知識・馬券の種類・AI予想の活用法など、初心者から中級者まで役立つ情報をまとめています。"
  keywords={['地方競馬', 'AI予想', '馬券', '競馬初心者', '記事一覧']}
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <!-- Page Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-black text-green-900 mb-2">記事一覧</h1>
      <p class="text-gray-500 text-sm">全 {sortedArticles.length} 件の記事</p>
      <div class="w-16 h-1 bg-yellow-500 mx-auto rounded mt-3"></div>
    </div>

    {sortedArticles.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sortedArticles.map((article) => (
          <ArticleCard
            slug={article.slug}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            keywords={article.data.keywords}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-400 text-lg">記事を準備中です。もうしばらくお待ちください。</p>
      </div>
    )}

    <!-- Disclaimer -->
    <div class="notice-box mt-12">
      <p class="font-bold mb-1">注意事項</p>
      <p>当サイトの予想・情報は確実な的中を保証するものではありません。馬券購入は20歳以上の方のみ可能です。</p>
    </div>
  </div>
</Layout>
