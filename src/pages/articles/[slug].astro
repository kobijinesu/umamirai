---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const formattedDate = article.data.publishedAt.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={article.data.title}
  description={article.data.description}
  publishedAt={article.data.publishedAt}
  keywords={article.data.keywords}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav aria-label="パンくずリスト" class="text-xs text-gray-400 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-green-700">ホーム</a>
      <span>/</span>
      <a href="/articles" class="hover:text-green-700">記事一覧</a>
      <span>/</span>
      <span class="text-gray-600 line-clamp-1">{article.data.title}</span>
    </nav>

    <!-- Article Header -->
    <header class="mb-8">
      <!-- Keywords -->
      {article.data.keywords.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {article.data.keywords.slice(0, 4).map((kw) => (
            <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full font-medium">
              {kw}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-2xl sm:text-3xl font-black text-gray-900 leading-snug mb-4">
        {article.data.title}
      </h1>

      <div class="flex items-center gap-4 text-sm text-gray-500 border-b border-gray-200 pb-4">
        <time datetime={article.data.publishedAt.toISOString()}>
          公開日: {formattedDate}
        </time>
        <span class="text-gray-300">|</span>
        <span>うまミライ編集部</span>
      </div>

      <!-- Description -->
      <p class="mt-4 text-gray-600 text-sm leading-relaxed bg-gray-50 rounded-lg p-4 border-l-4 border-green-700">
        {article.data.description}
      </p>
    </header>

    <!-- Article Content -->
    <div class="article-body">
      <Content />
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-green-50 border border-green-200 rounded-xl p-6 text-center">
      <p class="font-bold text-green-900 mb-2">他の記事もチェックしよう</p>
      <p class="text-sm text-gray-600 mb-4">地方競馬の基礎から攻略法まで、役立つ情報を揃えています。</p>
      <a href="/articles" class="btn-primary">記事一覧を見る</a>
    </div>

    <!-- Disclaimer -->
    <div class="notice-box mt-8">
      <p class="font-bold mb-2">注意事項</p>
      <ul class="space-y-1 text-xs">
        <li>・当サイトの予想は確実な的中を保証するものではありません。</li>
        <li>・馬券・車券の購入は20歳以上の方に限られます。</li>
        <li>・ギャンブル等依存症対策については <a href="https://www.gov-online.go.jp/" target="_blank" rel="noopener noreferrer" class="underline">政府広報オンライン</a> を参照してください。</li>
        <li>・当記事はアフィリエイトリンクを含む場合があります。</li>
      </ul>
    </div>

    <!-- Back to list -->
    <div class="text-center mt-8">
      <a href="/articles" class="text-sm text-green-700 underline hover:text-yellow-600">
        ← 記事一覧に戻る
      </a>
    </div>
  </article>
</Layout>
