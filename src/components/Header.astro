---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/articles', label: '記事一覧' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-green-900 text-white shadow-lg sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="うまミライ トップページ">
      <span class="text-yellow-400 text-2xl font-black tracking-tight group-hover:text-yellow-300 transition-colors">
        うまミライ
      </span>
      <span class="hidden sm:inline-block text-xs text-green-300 leading-tight">
        地方競馬<br />AI予想
      </span>
    </a>

    <!-- Navigation -->
    <nav aria-label="メインナビゲーション">
      <ul class="flex items-center gap-1 sm:gap-2">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                currentPath.startsWith(link.href)
                  ? 'bg-green-700 text-yellow-400'
                  : 'text-green-100 hover:bg-green-800 hover:text-yellow-300',
              ]}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/contact"
            class="ml-2 px-4 py-2 bg-yellow-500 text-green-900 text-sm font-bold rounded-lg hover:bg-yellow-400 transition-colors"
          >
            お問い合わせ
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
