---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  publishedAt?: Date;
  keywords?: string[];
}

const {
  title,
  description = '地方競馬をAIと一緒に楽しむ予想メディア。中央競馬にはない地方競馬の穴馬情報やデータ分析を毎日更新。',
  ogImage = '/og-image.svg',
  publishedAt,
  keywords = ['地方競馬', 'AI予想', '競馬予想', 'NAR', '地方競馬攻略'],
} = Astro.props;

const siteUrl = 'https://umamirai.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString();
const fullTitle = title === 'うまミライ' ? title : `${title} | うまミライ`;
const keywordsStr = keywords.join(', ');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Basic SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordsStr} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OGP -->
    <meta property="og:type" content={publishedAt ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="うまミライ" />
    <meta property="og:locale" content="ja_JP" />
    {publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />

    <!-- Structured Data (WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "うまミライ",
      "url": siteUrl,
      "description": "地方競馬AI予想メディア",
      "inLanguage": "ja",
    })} />
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
